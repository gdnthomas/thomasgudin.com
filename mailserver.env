# Configuration docker-mailserver — voir https://docker-mailserver.github.io/docker-mailserver/latest/config/environment/
# Profil « petit serveur » : DKIM/DMARC activés, antivirus lourd (ClamAV) désactivé.

# Adresse du postmaster (alias technique).
POSTMASTER_ADDRESS=postmaster@thomasgudin.com

# Niveau de logs : error | warn | info | debug | trace
LOG_LEVEL=info

# --- TLS ---
# La valeur SSL_TYPE est fixée dans docker-compose.mail.yml (letsencrypt).
# Forcer le chiffrement pour les connexions clients (submission/imap).
TLS_LEVEL=modern

# --- Sécurité / réseau ---
# 1 = autorise les conteneurs du même réseau Docker à relayer (utile si une app
# locale veut envoyer du mail). Mettre 0 pour être plus strict.
PERMIT_DOCKER=none
# Fail2Ban (bannit les IP qui brute-forcent). Nécessite cap_add NET_ADMIN.
ENABLE_FAIL2BAN=1

# --- Anti-spam / signatures ---
# Rspamd gère à la fois l'anti-spam ET la signature DKIM (recommandé par DMS).
ENABLE_RSPAMD=1
ENABLE_OPENDKIM=0
ENABLE_OPENDMARC=0
# Redis embarqué requis par Rspamd.
ENABLE_RSPAMD_REDIS=1
RSPAMD_GREYLISTING=1
# DMARC/SPF/DKIM vérifiés via Rspamd.
ENABLE_SPAMASSASSIN=0
ENABLE_AMAVIS=0
ENABLE_POSTGREY=0

# Antivirus ClamAV désactivé (consomme ~1 Go de RAM).
ENABLE_CLAMAV=0

# --- Boîtes / quotas ---
# Quotas Dovecot (désactivés par défaut, suffisant pour quelques boîtes).
ENABLE_QUOTAS=1

# Déplacer automatiquement le spam détecté dans le dossier Junk.
SPOOF_PROTECTION=1
MOVE_SPAM_TO_JUNK=1
